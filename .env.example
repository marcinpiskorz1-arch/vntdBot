# ============ Telegram ============
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ============ Gemini AI (optional) ============
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ============ Proxy ============
# LunaProxy (Dynamic Residential, Poland):
#   1. Panel → Dynamic Residential → Create endpoint
#   2. Region: Poland, Rotation: Sticky IP (10 min)
#   3. Format: http://USERNAME-region-pl:PASSWORD@pr.lunaproxy.com:12233
#
# Bot auto-appends sticky session IDs — set rotation to "per request" in panel,
# the code handles session pinning internally.
#
# Multiple proxies (comma-separated):
#   PROXY_URLS=http://user1:pass1@proxy1:port,http://user2:pass2@proxy2:port
PROXY_URLS=

# ============ Scan ============
SCAN_INTERVAL_MS=30000
DEAL_THRESHOLD=0.60

# ============ Database ============
DB_PATH=data/vintedbot.db
